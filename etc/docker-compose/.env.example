# Docker Compose secrets — copy to `.env` and fill with real values.
# `.env` is gitignored; never commit real secrets.
# docker-compose automatically reads `.env` from this directory.

# --- Public hostnames (per environment) ---
# These drive the backend URLs (docker-compose.yml) AND the nginx server_name (templates).
# main has NO hardcoded URLs — each server sets its own here.
#   LIVE  (production):  API_HOST=tfapi.beon-it.com       CONSOLE_HOST=tfconsole.beon-it.com
#   TEST  (staging):     API_HOST=tfapi-dev.beon-it.com   CONSOLE_HOST=tfconsole-dev.beon-it.com
API_HOST=
CONSOLE_HOST=

# --- Talabat credentials ---
TALABAT_PASSWORD=
TALABAT_SECRET=
TALABAT_STATIC_TOKEN=

# --- OpenIddict / AuthServer signing certificate passphrase ---
AUTHSERVER_CERT_PASSPHRASE=

# --- Database passwords ---
DB_PASSWORD=
DB_ROOT_PASSWORD=
