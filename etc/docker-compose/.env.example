# Docker Compose secrets — copy to `.env` and fill with real values.
# `.env` is gitignored; never commit real secrets.
# docker-compose automatically reads `.env` from this directory.

# --- Talabat credentials ---
TALABAT_PASSWORD=
TALABAT_SECRET=
TALABAT_STATIC_TOKEN=

# --- OpenIddict / AuthServer signing certificate passphrase ---
AUTHSERVER_CERT_PASSPHRASE=

# --- Database passwords ---
DB_PASSWORD=
DB_ROOT_PASSWORD=
